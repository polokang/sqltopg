{
  "name": "sql-to-pg-sync",
  "version": "1.0.0",
  "description": "实时同步 SQL Server 数据到 PostgreSQL",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "sync": "node src/sync-simple.js",
    "dev": "node --watch src/index.js",
    "init-db": "node src/initDatabase.js",
    "migrate:company": "node src/migration-company.js",
    "migrate:user": "node src/migration-user.js",
    "migrate:controller": "node src/migration-controller.js",
    "migrate:assignment": "node src/migration-assignment.js",
    "migrate": "node src/initDatabase.js && node src/migration-user.js && node src/migration-company.js && node src/migration-controller.js && node src/migration-assignment.js"
  },
  "keywords": [
    "sql-server",
    "postgresql",
    "sync"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.3.1",
    "mssql": "^10.0.1",
    "pg": "^8.20.0"
  }
}